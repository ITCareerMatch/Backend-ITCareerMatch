// ITCareerMatch - AI Career Matching Platform
// CC26-PSU088 | Coding Camp 2026 powered by DBS Foundation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String?
  email         String   @unique
  password_hash String?  @db.VarChar(255) @note("Null jika login via OAuth")
  auth_provider String   @note("email | google")
  gender        String?  @note("L | P | null")
  avatar_url    String?  @db.Text
  is_verified   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  deleted_at    DateTime? @note("Soft delete")

  cv_archives      CvArchive[]
  analysis_history AnalysisHistory[]

  @@map("users")
}

model Job {
  id               String    @id @default(uuid())
  title            String
  company_name     String
  category         String?
  experience_level String?
  job_type         String?
  requirements     String?   @db.Text
  location         String?
  gender_required  String?   @note("L | P | Both")
  salary_min       Int?
  salary_max       Int?
  external_url     String?   @db.Text
  source           String?
  is_active        Boolean   @default(true)
  scraped_at       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  analysis_history AnalysisHistory[]
  skills           JobSkill[]

  @@map("jobs")
}

model Skill {
  id   String @id @default(uuid())
  name String @unique
  type String @note("technical | soft")

  created_at DateTime @default(now())

  jobs           JobSkill[]
  cvs            CvSkill[]
  analysisDetails AnalysisDetail[]

  @@map("skills")
}

model CvArchive {
  id        String   @id @default(uuid())
  user_id   String
  file_name String
  file_url  String   @db.Text
  file_size Int?     @note("Ukuran dalam bytes")
  status    String   @note("active | archived")
  uploaded_at DateTime @default(now())
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user             User              @relation(fields: [user_id], references: [id])
  analysis_history AnalysisHistory[]
  skills           CvSkill[]

  @@map("cv_archives")
}

model AnalysisHistory {
  id                 String   @id @default(uuid())
  user_id            String
  cv_archive_id      String
  job_id             String?
  job_title_snapshot String   @note("Snapshot judul job saat analisis")
  company_snapshot   String   @note("Snapshot nama perusahaan")
  match_score        Decimal  @db.Decimal(5, 2) @note("Persentase 0.00 - 100.00")
  analyzed_at        DateTime @default(now())
  created_at         DateTime @default(now())

  user             User             @relation(fields: [user_id], references: [id])
  cv_archive       CvArchive        @relation(fields: [cv_archive_id], references: [id])
  job              Job?             @relation(fields: [job_id], references: [id], onDelete: SetNull)
  analysis_details AnalysisDetail[]

  @@map("analysis_history")
}

model AnalysisDetail {
  id                  String  @id @default(uuid())
  analysis_history_id String
  skill_id            String?
  skill_name_snapshot String  @note("Snapshot nama skill saat analisis")
  status              String  @note("match | gap")
  ai_insight          String? @db.Text @note("Saran perbaikan AI per skill")
  created_at          DateTime @default(now())

  analysis_history AnalysisHistory @relation(fields: [analysis_history_id], references: [id])
  skill            Skill?          @relation(fields: [skill_id], references: [id], onDelete: SetNull)

  @@map("analysis_details")
}

model GuestScan {
  id            String    @id @default(uuid())
  session_token String    @unique
  cv_file_url   String    @db.Text
  quick_score   Decimal?  @db.Decimal(5, 2) @note("Skor Kilat untuk guest")
  gender_input  String?   @note("L | P | null")
  scanned_at    DateTime  @default(now())
  expires_at    DateTime? @note("TTL sesi guest, misal 1 jam")

  @@map("guest_scans")
}

// Tabel pivot untuk relasi many-to-many antara Job dan Skill
model JobSkill {
  job_id   String
  skill_id String

  job   Job   @relation(fields: [job_id], references: [id])
  skill Skill @relation(fields: [skill_id], references: [id])

  @@id([job_id, skill_id])
  @@map("job_skills")
}

// Tabel pivot untuk relasi many-to-many antara CvArchive dan Skill
model CvSkill {
  cv_archive_id String
  skill_id      String
  confidence    Decimal? @db.Decimal(4, 3) @note("Confidence score AI 0.000 - 1.000")

  cv_archive CvArchive @relation(fields: [cv_archive_id], references: [id])
  skill      Skill     @relation(fields: [skill_id], references: [id])

  @@id([cv_archive_id, skill_id])
  @@map("cv_skills")
}
