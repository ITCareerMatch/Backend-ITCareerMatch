# Server Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres

# Supabase (Auth & Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AI Service (FastAPI)
AI_SERVICE_URL=http://localhost:8000

# Internal API Token (for Worker → Backend communication)
INTERNAL_REQUEST_TOKEN=your_internal_token_here

# Swagger/API Docs
SWAGGER_HOST=localhost:3000
SWAGGER_SCHEME=http

# Production Frontend URLs (for CORS)
FRONTEND_URL=https://itcareermatch.com

# Or for Railway deployment:
# FRONTEND_URL=https://itcareermatch.up.railway.app
